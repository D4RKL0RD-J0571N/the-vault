# The Vault Configuration Example
# Copy this file to .env and modify as needed

# Database Configuration
VAULT_DATABASE_URL=sqlite:///./vault.db

# Root Directories to Scan
# Comma-separated list of directories containing development projects
VAULT_ROOT_DIRECTORIES=/path/to/your/projects,/another/path

# API Server Configuration
VAULT_API_HOST=127.0.0.1
VAULT_API_PORT=8000

# Environment
# development, production, or test
VAULT_ENVIRONMENT=development

# Logging Level
# DEBUG, INFO, WARNING, ERROR, CRITICAL
VAULT_LOG_LEVEL=DEBUG

# Parser Settings
VAULT_MAX_FILE_SIZE_MB=10

# File Exclusion Patterns
# Directories and files to skip during scanning
VAULT_EXCLUDE_PATTERNS=.git,node_modules,__pycache__,.vscode,.idea,build,dist,target,bin,obj,.venv,venv,env
